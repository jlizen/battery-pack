[package]
name = "{{project-name}}"
version = "0.1.0"
edition = "2024"
description = "A CLI application with subcommands"
license = "MIT OR Apache-2.0"

[dependencies]
anyhow = "1"
clap = { version = "4", features = ["derive"] }
dialoguer = "0.11"
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter"] }

[build-dependencies]
cli-battery-pack = "0.4"
logging-battery-pack = "0.4"

[package.metadata.battery-pack.cli-battery-pack]
features = ["default"]

[package.metadata.battery-pack.logging-battery-pack]
features = ["default"]
